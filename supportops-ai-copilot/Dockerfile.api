FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/apps/api:/app/packages/db:/app/packages/domain:/app/packages/model_gateway:/app/packages/prompts:/app/packages/evals:/app/packages/observability

WORKDIR /app

COPY requirements.txt .
RUN python -m pip install --no-cache-dir --upgrade pip \
    && python -m pip install --no-cache-dir -r requirements.txt

COPY alembic.ini .
COPY apps ./apps
COPY packages ./packages

EXPOSE 8765

CMD ["python", "-m", "uvicorn", "supportops_api.main:app", "--host", "0.0.0.0", "--port", "8765"]
